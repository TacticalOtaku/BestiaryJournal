<section class="creature-detail-wrapper bestiary-scrollable">
  {{#if error}}
    <div class="bestiary-error">
      <i class="fas fa-exclamation-triangle"></i>
      <p>Could not load creature data.</p>
    </div>
  {{else}}
    <div class="creature-detail-view detail-{{detailLevel}}">

      {{!-- Detail level selector --}}
      {{#if canToggleDetail}}
        <nav class="detail-level-nav">
          <button type="button" class="detail-level-btn {{#if isMinimal}}active{{/if}}" data-action="setDetailLevel" data-level="minimal">
            {{localize "BESTIARY.ViewMinimal"}}
          </button>
          <button type="button" class="detail-level-btn {{#if isStandard}}active{{/if}}" data-action="setDetailLevel" data-level="standard">
            {{localize "BESTIARY.ViewStandard"}}
          </button>
          <button type="button" class="detail-level-btn {{#if isExpanded}}active{{/if}}" data-action="setDetailLevel" data-level="expanded">
            {{localize "BESTIARY.ViewExpanded"}}
          </button>
          {{#if isGM}}
            <button type="button" class="detail-level-btn {{#if isCustom}}active{{/if}}" data-action="setDetailLevel" data-level="custom">
              <i class="fas fa-sliders"></i> {{localize "BESTIARY.ViewCustom"}}
            </button>
          {{/if}}
          {{#if isGM}}
            <button type="button" class="detail-level-btn btn-open-sheet" data-action="openSheet" data-tooltip="{{localize 'BESTIARY.OpenSheet'}}">
              <i class="fas fa-scroll"></i>
            </button>
          {{/if}}
        </nav>
      {{else}}
        {{#if isGM}}
          <nav class="detail-level-nav">
            <button type="button" class="detail-level-btn btn-open-sheet" data-action="openSheet" data-tooltip="{{localize 'BESTIARY.OpenSheet'}}">
              <i class="fas fa-scroll"></i>
            </button>
          </nav>
        {{/if}}
      {{/if}}

      {{!-- Custom mode config panel (GM only) --}}
      {{#if isCustom}}
        {{#if isGM}}
          <div class="custom-display-config">
            <h4 class="custom-config-title"><i class="fas fa-sliders"></i> {{localize "BESTIARY.CustomConfig"}}</h4>
            <div class="custom-block-groups">
              {{#each groupedDisplayBlocks}}
                <section class="custom-block-group">
                  <h5 class="custom-block-group-title">{{this.label}}</h5>
                  <div class="custom-blocks-grid">
                    {{#each this.blocks}}
                      <label class="custom-block-toggle {{#if this.isChild}}is-child{{/if}}">
                        <input type="checkbox" {{#if this.visible}}checked{{/if}} data-block-key="{{this.key}}" />
                        <span>{{this.localizedLabel}}</span>
                      </label>
                    {{/each}}
                  </div>
                </section>
              {{/each}}
            </div>
          </div>
        {{/if}}
      {{/if}}

      {{!-- Hero Section (always visible) --}}
      <div class="creature-hero">
        <div class="creature-portrait">
          <img src="{{creature.img}}" alt="{{creature.name}}" />
        </div>
        <div class="creature-hero-info">
          <h1 class="creature-name">{{creature.name}}</h1>
          <p class="creature-type-line">{{creature.typeLabel}}{{#if creature.alignment}}, {{creature.alignment}}{{/if}}</p>
          <div class="creature-key-stats">
            <div class="key-stat">
              <span class="key-stat-label">{{localize "BESTIARY.AC"}}</span>
              <span class="key-stat-value">{{creature.ac.value}}</span>
            </div>
            <div class="key-stat">
              <span class="key-stat-label">{{localize "BESTIARY.HP"}}</span>
              <span class="key-stat-value">{{creature.hp.max}}{{#if creature.hp.formula}} <small>({{creature.hp.formula}})</small>{{/if}}</span>
            </div>
            <div class="key-stat">
              <span class="key-stat-label">{{localize "BESTIARY.CR"}}</span>
              <span class="key-stat-value">{{creature.crFormatted}}{{#if creature.xp}} <small>({{creature.xp}} XP)</small>{{/if}}</span>
            </div>
          </div>
          {{#if speedEntries.length}}
            <div class="creature-speed">
              <strong>{{localize "BESTIARY.Speed"}}:</strong>
              {{#each speedEntries}}
                {{#if this.label}}<span class="speed-type">{{this.label}}</span>{{/if}}
                <span class="speed-value">{{this.value}}</span>{{#unless @last}},{{/unless}}
              {{/each}}
            </div>
          {{/if}}
        </div>
      </div>

      {{!-- Extended content (everything except minimal) --}}
      {{#if isNotMinimal}}

        {{#if showAbilitiesSection}}
          <div class="creature-abilities">
            <h3 class="section-divider">{{localize "BESTIARY.Abilities"}}</h3>
            <div class="ability-scores-grid">
              {{#each abilityEntries}}
                <div class="ability-score {{#if this.isHighlight}}highlight{{/if}}">
                  <span class="ability-label">{{this.label}}</span>
                  <span class="ability-value">{{this.value}}</span>
                  <span class="ability-mod">({{this.mod}})</span>
                </div>
              {{/each}}
            </div>
          </div>
        {{/if}}

        <div class="creature-traits">
          {{#if showBlock.skills}}
            <div class="trait-line"><strong>{{localize "BESTIARY.Skills"}}:</strong> {{#each skillEntries}}{{this.label}} {{this.total}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if showBlock.senses}}
            <div class="trait-line"><strong>{{localize "BESTIARY.Senses"}}:</strong> {{#each senseEntries}}{{this.label}} {{this.value}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if showBlock.languages}}
            <div class="trait-line"><strong>{{localize "BESTIARY.Languages"}}:</strong> {{#each creature.languages}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if showBlock.resistances}}
            <div class="trait-line"><strong>{{localize "BESTIARY.Resistances"}}:</strong> {{#each creature.resistances}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if showBlock.immunities}}
            <div class="trait-line"><strong>{{localize "BESTIARY.Immunities"}}:</strong> {{#each creature.immunities}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if showBlock.vulnerabilities}}
            <div class="trait-line"><strong>{{localize "BESTIARY.Vulnerabilities"}}:</strong> {{#each creature.vulnerabilities}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
          {{#if showBlock.conditionImmunities}}
            <div class="trait-line"><strong>{{localize "BESTIARY.ConditionImmunities"}}:</strong> {{#each creature.conditionImmunities}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
          {{/if}}
        </div>

        {{#if showBlock.features}}
          <div class="creature-items-section creature-items-accordion {{#if sectionState.features}}is-expanded{{/if}}">
            <button type="button" class="section-divider section-toggle" data-action="toggleSection" data-section-key="features">
              <span>{{localize "BESTIARY.Features"}}</span>
              <i class="fas {{#if sectionState.features}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
            </button>
            <div class="accordion-section-body {{#unless sectionState.features}}is-collapsed{{/unless}}">
              <div class="creature-items-list">
                {{#each features}}
                  <div class="creature-item {{#if this._expanded}}is-expanded{{/if}}" data-item-name="{{this.name}}" data-action="expandItem">
                    <div class="creature-item-header">
                      {{#if this.img}}<img class="item-icon" src="{{this.img}}" alt="" />{{/if}}
                      <span class="item-name">{{this.name}}</span>
                      {{#if this.activities.length}}
                        <span class="item-activity-count">{{this.activities.length}}</span>
                      {{/if}}
                      <i class="fas {{#if this._expanded}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
                    </div>
                      <div class="creature-item-body {{#unless this._expanded}}is-collapsed{{/unless}}">
                        {{#if this.hasMeta}}
                          <div class="creature-item-meta">
                            {{#if this.tags.length}}
                              <div class="creature-item-tags">
                                {{#each this.tags}}
                                  <span class="item-tag {{#if this.isAccent}}is-accent{{/if}}">
                                    <strong>{{localize this.label}}:</strong> {{this.value}}
                                  </span>
                                {{/each}}
                              </div>
                            {{/if}}
                            {{#if this.stats.length}}
                              <div class="creature-item-stats">
                                {{#each this.stats}}
                                  <div class="item-stat">
                                    <span class="item-stat-label">{{localize this.label}}</span>
                                    <span class="item-stat-value">{{this.value}}</span>
                                  </div>
                                {{/each}}
                              </div>
                            {{/if}}
                            {{#if this.activities.length}}
                              <div class="creature-item-activities">
                                <div class="item-subsection-title">{{localize "BESTIARY.ItemActivities"}}</div>
                                <div class="activity-list">
                                  {{#each this.activities}}
                                    <div class="activity-row">
                                      <div class="activity-main">
                                        <span class="activity-name">{{this.name}}</span>
                                        <span class="activity-type">{{this.typeLabel}}</span>
                                      </div>
                                      <div class="activity-details">
                                        {{#if this.activationLabel}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemActivation"}}:</strong> {{this.activationLabel}}</span>{{/if}}
                                        {{#if this.attack}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemAttack"}}:</strong> {{this.attack}}</span>{{/if}}
                                        {{#if this.damage}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemDamage"}}:</strong> {{this.damage}}</span>{{/if}}
                                        {{#if this.save}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemSave"}}:</strong> {{this.save}}</span>{{/if}}
                                        {{#if this.range}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemRange"}}:</strong> {{this.range}}</span>{{/if}}
                                        {{#if this.target}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemTarget"}}:</strong> {{this.target}}</span>{{/if}}
                                        {{#if this.uses}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemUses"}}:</strong> {{this.uses}}</span>{{/if}}
                                      </div>
                                    </div>
                                  {{/each}}
                                </div>
                              </div>
                            {{/if}}
                          </div>
                        {{/if}}
                        {{#if this.description}}<div class="creature-item-description">{{{this.description}}}</div>{{/if}}
                      </div>
                  </div>
                {{/each}}
              </div>
            </div>
          </div>
        {{/if}}

        {{#if showBlock.actions}}
