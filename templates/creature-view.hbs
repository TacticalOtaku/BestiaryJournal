        {{#if showBlock.reactions}}
          <div class="creature-items-section creature-items-accordion {{#if sectionState.reactions}}is-expanded{{/if}}">
            <button type="button" class="section-divider section-toggle" data-action="toggleSection" data-section-key="reactions">
              <span>{{localize "BESTIARY.Reactions"}}</span>
              <i class="fas {{#if sectionState.reactions}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
            </button>
            <div class="accordion-section-body {{#unless sectionState.reactions}}is-collapsed{{/unless}}">
              <div class="creature-items-list">
