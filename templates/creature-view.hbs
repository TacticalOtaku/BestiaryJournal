                            {{/if}}
                            {{#if this.stats.length}}
                              <div class="creature-item-stats">
                                {{#each this.stats}}
                                  <div class="item-stat">
                                    <span class="item-stat-label">{{localize this.label}}</span>
                                    <span class="item-stat-value">{{this.value}}</span>
                                  </div>
                                {{/each}}
                              </div>
                            {{/if}}
                            {{#if this.activities.length}}
                              <div class="creature-item-activities">
                                <div class="item-subsection-title">{{localize "BESTIARY.ItemActivities"}}</div>
                                <div class="activity-list">
                                  {{#each this.activities}}
                                    <div class="activity-row">
                                      <div class="activity-main">
                                        <span class="activity-name">{{this.name}}</span>
                                        <span class="activity-type">{{this.typeLabel}}</span>
                                      </div>
                                      <div class="activity-details">
                                        {{#if this.activationLabel}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemActivation"}}:</strong> {{this.activationLabel}}</span>{{/if}}
                                        {{#if this.attack}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemAttack"}}:</strong> {{this.attack}}</span>{{/if}}
                                        {{#if this.damage}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemDamage"}}:</strong> {{this.damage}}</span>{{/if}}
                                        {{#if this.save}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemSave"}}:</strong> {{this.save}}</span>{{/if}}
                                        {{#if this.range}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemRange"}}:</strong> {{this.range}}</span>{{/if}}
                                        {{#if this.target}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemTarget"}}:</strong> {{this.target}}</span>{{/if}}
                                        {{#if this.uses}}<span class="activity-detail"><strong>{{localize "BESTIARY.ItemUses"}}:</strong> {{this.uses}}</span>{{/if}}
                                      </div>
                                    </div>
                                  {{/each}}
                                </div>
                              </div>
                            {{/if}}
                          </div>
                        {{/if}}
                        {{#if this.description}}<div class="creature-item-description">{{{this.description}}}</div>{{/if}}
                      </div>
                  </div>
                {{/each}}
              </div>
            </div>
          </div>
        {{/if}}

        {{#if showBlock.legendaryActions}}
          <div class="creature-items-section creature-items-accordion {{#if sectionState.legendaryActions}}is-expanded{{/if}}">
            <button type="button" class="section-divider section-toggle legendary" data-action="toggleSection" data-section-key="legendaryActions">
              <span>{{localize "BESTIARY.LegendaryActions"}}</span>
              <i class="fas {{#if sectionState.legendaryActions}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
            </button>
            <div class="accordion-section-body {{#unless sectionState.legendaryActions}}is-collapsed{{/unless}}">
              <div class="creature-items-list">
                {{#each legendaryActions}}
                  <div class="creature-item {{#if this._expanded}}is-expanded{{/if}}" data-item-name="{{this.name}}" data-action="expandItem">
                    <div class="creature-item-header">
                      {{#if this.img}}<img class="item-icon" src="{{this.img}}" alt="" />{{/if}}
                      <span class="item-name">{{this.name}}</span>
                      <i class="fas {{#if this._expanded}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
                    </div>
                    <div class="creature-item-body {{#unless this._expanded}}is-collapsed{{/unless}}">
                      <div class="creature-item-description">{{{this.description}}}</div>
                    </div>
                  </div>
                {{/each}}
              </div>
            </div>
          </div>
        {{/if}}

        {{#if showBlock.spells}}
          <div class="creature-items-section creature-items-accordion {{#if sectionState.spells}}is-expanded{{/if}}">
            <button type="button" class="section-divider section-toggle" data-action="toggleSection" data-section-key="spells">
              <span>{{localize "BESTIARY.Spellcasting"}}</span>
              <i class="fas {{#if sectionState.spells}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
            </button>
            <div class="accordion-section-body {{#unless sectionState.spells}}is-collapsed{{/unless}}">
              <div class="creature-spells-list">
                {{#each spells}}
                  <div class="creature-spell-item">
                    {{#if this.img}}<img class="item-icon" src="{{this.img}}" alt="" />{{/if}}
                    <span class="spell-name">{{this.name}}</span>
                    <span class="spell-level">(Lvl {{this.level}})</span>
                  </div>
                {{/each}}
              </div>
            </div>
          </div>
        {{/if}}

        {{#if showBlock.biography}}
          <div class="creature-items-section creature-items-accordion {{#if sectionState.biography}}is-expanded{{/if}}">
            <button type="button" class="section-divider section-toggle" data-action="toggleSection" data-section-key="biography">
              <span>{{localize "BESTIARY.Biography"}}</span>
              <i class="fas {{#if sectionState.biography}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
            </button>
            <div class="accordion-section-body {{#unless sectionState.biography}}is-collapsed{{/unless}}">
              <div class="biography-content creature-biography-content">{{{creature.biography}}}</div>
            </div>
          </div>
        {{/if}}

      {{/if}}
    </div>
  {{/if}}
</section>
